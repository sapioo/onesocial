# Copy of .env with the AI_PROVIDER keys stripped out.
# Use this as a reference for required environment variables.

# ── General ──────────────────────────────────────
PORT=5000
VITE_API_URL=http://localhost:5000

# ── AI Provider Selection ─────────────────────────
# Set to "openrouter" or "bedrock"
AI_PROVIDER=openrouter

# ── OpenRouter ────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_CAPTION_MODEL=mistralai/mistral-small
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# ── Amazon Bedrock (optional backup) ─────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#AWS_REGION=us-east-1
#BEDROCK_CAPTION_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
#BEDROCK_IMAGE_MODEL_ID=stability.stable-diffusion-xl-v1
